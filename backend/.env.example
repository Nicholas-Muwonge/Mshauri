# --- Payment provider selection ---
# 'momo' = direct MTN MoMo Collections API (no middleman)
# 'flutterwave' (or unset) = Flutterwave aggregator
# Either way, if the chosen provider's credentials below are missing, payments run in
# clearly-labeled SIMULATION MODE — the whole app is testable with zero payment setup.
PAYMENT_PROVIDER=momo

# --- Direct MTN MoMo Collections API (used when PAYMENT_PROVIDER=momo) ---
# Sign up at https://momodeveloper.mtn.com, subscribe to the "Collections" product,
# then provision an API user + API key via their sandbox/production provisioning endpoint.
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CALLBACK_URL=

# --- Flutterwave aggregator (used when PAYMENT_PROVIDER=flutterwave) ---
# Get this from https://dashboard.flutterwave.com (Uganda merchant account)
FLUTTERWAVE_SECRET_KEY=
PAYMENT_REDIRECT_URL=http://localhost:5173/payment-complete

# --- Required for real AI responses ---
# Get this from https://aistudio.google.com/app/apikey (or Vertex AI for production scale)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Optional: WhatsApp bot via Twilio ---
# Get these from https://console.twilio.com (enable WhatsApp sandbox or production number)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Server ---
PORT=8080
